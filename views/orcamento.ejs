<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Solicitar serviço</title>
    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/orcamento.css">
</head>

<body class="orcamento-page">
    <%- include('partials/header') %>
        <main class="orcamento-container">
            <div class="orcamento-card">

                <h1>Selecionar Serviço</h1>
                <p>Selecione os serviços em que você tem interesse:</p>

                <form action="/orcamento" method="POST">

                    <div class="checkbox-group">
                        <input type="checkbox" id="estrategia" name="servicos" value="estrategia">
                        <label for="estrategia">Estratégia</label>
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="design" name="servicos" value="design">
                        <label for="design">Identidade visual</label>
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="calendario" name="servicos" value="calendario">
                        <label for="calendario">Calendário editorial</label>
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="gestao" name="servicos" value="gestao">
                        <label for="gestao">Gestão de redes</label>
                    </div>

                    <div class="checkbox-group">
                        <input type="checkbox" id="relatorio" name="servicos" value="relatorio">
                        <label for="relatorio">Relatórios</label>
                    </div>

                    <div class="actions">
                        <a href="/" class="btn-secondary" aria-label="Voltar para a página inicial">Voltar</a>
                        <button type="submit" class="btn-primary">Enviar</button>
                    </div>

                </form>
            </div>
            <footer class="footer">
                <%- include('partials/footer') %>
            </footer>
        </main>

        <%- include('partials/libras') %>
            <script src="/js/menu.js"></script>

</body>

</html>