<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar conta</title>
    <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/login.css">
</head>

<body class="login-page">

    <main class="login-container">

        <div class="login-card">
            <a href="/" class="logo">
                <img src="/img/img-logo.png" alt="Logo da Agência Wolf">
                <span class="logo-text">Agência Wolf</span>
            </a>

            <h1>Criar conta</h1>

            <% if (ok) { %>
                <div class="success-message">
                    <p>Conta criada com sucesso!</p>
                </div>
                <% } %>

                    <% if (error) { %>
                        <div class="error-message">
                            <p>
                                <%= error %>
                            </p>
                        </div>
                        <% } %>

                            <form action="/cadastro" method="POST" autocomplete="off">

                                <div class="input-group">
                                    <label for="name">Nome</label>
                                    <input type="text" id="name" name="nome" placeholder="Digite seu nome" required
                                        autofocus>
                                </div>

                                <div class="input-group">
                                    <label for="email">Email</label>
                                    <input type="email" id="email" name="email" placeholder="Digite seu email" required>
                                </div>

                                <div class="input-group">
                                    <label for="password">Senha</label>
                                    <input type="password" id="password" name="senha" placeholder="Digite sua senha"
                                        required>
                                </div>

                                <div class="input-group">
                                    <label for="confirmPassword">Confirmar senha</label>
                                    <input type="password" id="confirmPassword" name="senha2"
                                        placeholder="Confirme sua senha" required>
                                </div>

                                <p class="helper-text">
                                    Já tem uma conta? <a href="/login">Entrar</a>
                                </p>

                                <div class="actions">
                                    <button type="submit" class="btn-primary">
                                        Cadastrar
                                    </button>
                                </div>

                            </form>
        </div>
    </main>
    <%- include('partials/footer') %>
        <%- include('partials/libras') %>
</body>

</html>